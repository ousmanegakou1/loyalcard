<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<meta name="theme-color" content="#0a0f0a"/>
<title>LoyalCard — Inscription</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@700;900&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
/* ── RESET & BASE ── */
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html{height:100%;scroll-behavior:smooth}
body{
  font-family:'DM Sans',sans-serif;
  background:#0a0f0a;
  color:#f0ede8;
  min-height:100%;
  min-height:100svh;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}

/* ── VARIABLES ── */
:root{
  --green:#16a34a;
  --green2:#22c55e;
  --green3:#4ade80;
  --greenlt:#052e16;
  --greenmid:#14532d;
  --gold:#f5c842;
  --wave:#00c4a3;
  --orange:#f97316;
  --surface:#111a11;
  --surface2:#192019;
  --surface3:#1f2d1f;
  --border:rgba(34,197,94,0.12);
  --border2:rgba(34,197,94,0.22);
  --tx:#f0ede8;
  --tx2:#9aab96;
  --tx3:#4a5e47;
  --r:14px;
  --r2:20px;
  --r3:28px;
}

/* ── LAYOUT ── */
.app{
  display:flex;
  flex-direction:column;
  min-height:100svh;
  max-width:480px;
  margin:0 auto;
  position:relative;
}

/* ── BACKGROUND ── */
.bg-glow{
  position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden;
}
.bg-glow::before{
  content:'';position:absolute;
  top:-30vh;left:50%;transform:translateX(-50%);
  width:80vw;height:80vw;
  background:radial-gradient(circle,rgba(22,163,74,.18) 0%,transparent 70%);
}
.bg-glow::after{
  content:'';position:absolute;
  bottom:-20vh;right:-20vw;
  width:60vw;height:60vw;
  background:radial-gradient(circle,rgba(0,196,163,.08) 0%,transparent 70%);
}

/* ── HEADER ── */
.header{
  position:relative;z-index:10;
  padding:20px 24px 0;
  display:flex;align-items:center;justify-content:space-between;
}
.logo{
  font-family:'Fraunces',serif;
  font-size:1.3rem;font-weight:900;
  letter-spacing:-0.02em;color:var(--tx);
}
.logo span{color:var(--green2)}
.back-btn{
  width:38px;height:38px;border-radius:50%;
  background:var(--surface2);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;font-size:1.1rem;color:var(--tx2);
  transition:all .2s;
}
.back-btn:hover{background:var(--surface3);color:var(--tx)}

/* ── PROGRESS ── */
.progress-wrap{
  position:relative;z-index:10;
  padding:20px 24px 0;
  display:flex;align-items:center;gap:10px;
}
.prog-steps{display:flex;gap:6px;flex:1}
.prog-step{
  flex:1;height:3px;border-radius:20px;
  background:var(--surface3);overflow:hidden;
}
.prog-fill{
  height:100%;border-radius:20px;
  background:linear-gradient(90deg,var(--green),var(--green2));
  transition:width .4s cubic-bezier(.4,0,.2,1);
}
.prog-label{
  font-family:'DM Mono',monospace;
  font-size:.68rem;color:var(--tx3);
  white-space:nowrap;
}

/* ── MAIN CONTENT ── */
.content{
  position:relative;z-index:10;
  flex:1;display:flex;flex-direction:column;
  padding:28px 24px 32px;
}

/* ── STEP ── */
.step{display:none;flex-direction:column;flex:1;animation:stepIn .35s ease}
.step.active{display:flex}
@keyframes stepIn{
  from{opacity:0;transform:translateY(16px)}
  to{opacity:1;transform:none}
}

/* ── STEP ICON ── */
.step-icon{
  font-size:3rem;margin-bottom:20px;
  animation:iconPop .4s cubic-bezier(.34,1.56,.64,1);
}
@keyframes iconPop{from{transform:scale(.5);opacity:0}to{transform:scale(1);opacity:1}}

/* ── STEP TEXTS ── */
.step-title{
  font-family:'Fraunces',serif;
  font-size:1.9rem;font-weight:900;
  line-height:1.1;letter-spacing:-0.02em;
  color:var(--tx);margin-bottom:8px;
}
.step-title em{color:var(--green2);font-style:normal}
.step-sub{
  font-size:.9rem;color:var(--tx2);
  line-height:1.6;margin-bottom:32px;font-weight:300;
}

/* ── PHONE INPUT ── */
.phone-row{
  display:flex;gap:10px;align-items:stretch;margin-bottom:14px;
}
.country-badge{
  display:flex;align-items:center;gap:7px;
  background:var(--surface2);border:1.5px solid var(--border2);
  border-radius:var(--r);padding:0 14px;
  font-family:'DM Mono',monospace;font-size:.82rem;
  color:var(--tx2);white-space:nowrap;flex-shrink:0;
  cursor:default;
}
.country-flag{font-size:1.1rem}
.phone-input{
  flex:1;padding:15px 16px;
  background:var(--surface2);
  border:1.5px solid var(--border);
  border-radius:var(--r);
  font-family:'DM Mono',monospace;font-size:1.05rem;
  color:var(--tx);letter-spacing:.08em;
  outline:none;transition:border-color .2s,box-shadow .2s;
  -webkit-appearance:none;
}
.phone-input:focus{
  border-color:var(--green2);
  box-shadow:0 0 0 3px rgba(34,197,94,.12);
}
.phone-input::placeholder{color:var(--tx3)}

/* ── OTP INPUT ── */
.otp-row{
  display:flex;gap:10px;justify-content:center;
  margin-bottom:16px;
}
.otp-digit{
  width:60px;height:68px;
  background:var(--surface2);border:1.5px solid var(--border);
  border-radius:var(--r);
  font-family:'Fraunces',serif;font-size:1.8rem;font-weight:700;
  color:var(--tx);text-align:center;
  outline:none;transition:border-color .2s,box-shadow .2s;
  -webkit-appearance:none;caret-color:var(--green2);
}
.otp-digit:focus{
  border-color:var(--green2);
  box-shadow:0 0 0 3px rgba(34,197,94,.15);
}
.otp-digit.filled{border-color:var(--green);background:rgba(22,163,74,.06)}

/* ── TYPE SELECTOR ── */
.type-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:10px;margin-bottom:20px;
}
.type-card{
  background:var(--surface2);border:1.5px solid var(--border);
  border-radius:var(--r2);padding:18px 14px;
  cursor:pointer;transition:all .18s;
  text-align:center;
  -webkit-tap-highlight-color:transparent;
}
.type-card:hover,.type-card:active{
  border-color:var(--green);background:rgba(22,163,74,.06);
}
.type-card.selected{
  border-color:var(--green2);background:rgba(22,163,74,.1);
}
.type-emoji{font-size:1.8rem;margin-bottom:8px;display:block}
.type-name{
  font-size:.82rem;font-weight:600;color:var(--tx);margin-bottom:2px;
}
.type-hint{font-size:.68rem;color:var(--tx3)}

/* ── REWARD SECTION ── */
.reward-num-row{
  display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;
}
.rnum-btn{
  flex:1;min-width:52px;padding:14px 10px;
  background:var(--surface2);border:1.5px solid var(--border);
  border-radius:var(--r);cursor:pointer;
  font-family:'Fraunces',serif;font-size:1.3rem;font-weight:700;
  color:var(--tx2);text-align:center;transition:all .18s;
}
.rnum-btn:hover,.rnum-btn:active{
  border-color:var(--green);color:var(--tx);
}
.rnum-btn.selected{
  border-color:var(--green2);background:rgba(22,163,74,.1);color:var(--green2);
}
.reward-input-wrap{position:relative;margin-bottom:20px}
.reward-input{
  width:100%;padding:15px 16px;
  background:var(--surface2);border:1.5px solid var(--border);
  border-radius:var(--r);font-family:'DM Sans',sans-serif;font-size:.95rem;
  color:var(--tx);outline:none;transition:border-color .2s,box-shadow .2s;
  -webkit-appearance:none;
}
.reward-input:focus{
  border-color:var(--green2);
  box-shadow:0 0 0 3px rgba(34,197,94,.12);
}
.reward-input::placeholder{color:var(--tx3)}
.reward-examples{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:8px}
.rex{
  background:var(--surface3);border:1px solid var(--border);
  border-radius:20px;padding:5px 12px;
  font-size:.72rem;color:var(--tx2);cursor:pointer;
  transition:all .15s;
}
.rex:hover,.rex:active{border-color:var(--green);color:var(--green2)}

/* ── SHOP NAME INPUT ── */
.shop-input{
  width:100%;padding:16px 18px;
  background:var(--surface2);border:1.5px solid var(--border);
  border-radius:var(--r);font-family:'DM Sans',sans-serif;font-size:1.05rem;
  color:var(--tx);outline:none;transition:border-color .2s,box-shadow .2s;
  -webkit-appearance:none;margin-bottom:12px;
}
.shop-input:focus{
  border-color:var(--green2);
  box-shadow:0 0 0 3px rgba(34,197,94,.12);
}
.shop-input::placeholder{color:var(--tx3)}

/* ── CTA BUTTON ── */
.cta{
  width:100%;padding:17px;
  background:var(--green);color:#fff;
  border:none;border-radius:var(--r);
  font-family:'DM Sans',sans-serif;font-size:1rem;font-weight:600;
  cursor:pointer;transition:all .2s;
  display:flex;align-items:center;justify-content:center;gap:10px;
  margin-top:auto;
  -webkit-tap-highlight-color:transparent;
}
.cta:hover{background:#15803d}
.cta:active{transform:scale(.98)}
.cta:disabled{opacity:.45;cursor:not-allowed}
.cta.loading{pointer-events:none}

/* ── SECONDARY BTN ── */
.cta-ghost{
  width:100%;padding:13px;
  background:transparent;color:var(--tx2);
  border:1.5px solid var(--border);border-radius:var(--r);
  font-family:'DM Sans',sans-serif;font-size:.9rem;font-weight:500;
  cursor:pointer;transition:all .2s;
  display:flex;align-items:center;justify-content:center;gap:8px;
  margin-top:10px;
}
.cta-ghost:hover{border-color:var(--border2);color:var(--tx)}
.cta-ghost:active{transform:scale(.98)}

/* ── SPINNER ── */
.spin{
  width:18px;height:18px;
  border:2.5px solid rgba(255,255,255,.25);
  border-top-color:#fff;border-radius:50%;
  animation:sp .7s linear infinite;display:none;
}
.cta.loading .spin{display:inline-block}
.cta.loading .cta-label{display:none}
@keyframes sp{to{transform:rotate(360deg)}}

/* ── HINT LINE ── */
.hint{
  font-size:.75rem;color:var(--tx3);
  display:flex;align-items:center;gap:5px;
  margin-bottom:12px;
}

/* ── WAVE PILL ── */
.wave-pill{
  display:inline-flex;align-items:center;gap:7px;
  background:rgba(0,196,163,.08);border:1px solid rgba(0,196,163,.2);
  border-radius:20px;padding:6px 14px;margin-bottom:24px;
}
.wave-dot{width:7px;height:7px;border-radius:50%;background:var(--wave);animation:blink 2s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.wave-txt{font-family:'DM Mono',monospace;font-size:.7rem;color:var(--wave);letter-spacing:.3px}

/* ── SUCCESS STATE ── */
.success-wrap{
  flex:1;display:flex;flex-direction:column;
  align-items:center;justify-content:center;text-align:center;
  padding:40px 24px;
}
.success-icon{
  font-size:4.5rem;margin-bottom:24px;
  animation:successPop .5s cubic-bezier(.34,1.56,.64,1);
}
@keyframes successPop{from{transform:scale(0) rotate(-20deg)}to{transform:scale(1) rotate(0)}}
.success-title{
  font-family:'Fraunces',serif;font-size:2.2rem;font-weight:900;
  color:var(--tx);margin-bottom:12px;letter-spacing:-0.02em;
}
.success-title em{color:var(--green2);font-style:normal}
.success-sub{font-size:.9rem;color:var(--tx2);line-height:1.6;margin-bottom:32px;max-width:320px}

/* ── CONFIRM CARD ── */
.confirm-card{
  background:var(--surface2);border:1.5px solid var(--border2);
  border-radius:var(--r2);padding:18px;margin-bottom:28px;
  text-align:left;width:100%;
}
.confirm-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:8px 0;border-bottom:1px solid var(--border);font-size:.84rem;
}
.confirm-row:last-child{border-bottom:none}
.confirm-key{color:var(--tx3);font-size:.72rem;text-transform:uppercase;letter-spacing:.06em}
.confirm-val{color:var(--tx);font-weight:600}

/* ── RESEND ── */
.resend-row{text-align:center;margin-top:14px}
.resend-btn{
  background:none;border:none;cursor:pointer;
  font-family:'DM Sans',sans-serif;font-size:.8rem;color:var(--tx3);
  transition:color .2s;
}
.resend-btn:not(:disabled):hover{color:var(--green2)}
.resend-btn:disabled{cursor:default}
#resend-count{color:var(--tx3)}

/* ── LATER LINK ── */
.later-link{
  text-align:center;margin-top:14px;
  font-size:.78rem;color:var(--tx3);cursor:pointer;transition:color .2s;
}
.later-link:hover{color:var(--tx2)}

/* ── TOAST ── */
.toast-wrap{
  position:fixed;bottom:24px;left:50%;transform:translateX(-50%);
  z-index:9999;pointer-events:none;
  display:flex;flex-direction:column;gap:8px;align-items:center;
}
.toast{
  background:var(--surface3);border:1px solid var(--border2);
  border-radius:var(--r);padding:11px 20px;
  font-size:.82rem;font-weight:500;
  box-shadow:0 8px 24px rgba(0,0,0,.5);
  animation:toastIn .3s ease;white-space:nowrap;
  display:flex;align-items:center;gap:8px;
}
.toast.ok{border-left:3px solid var(--green2);color:var(--green3)}
.toast.err{border-left:3px solid #f87171;color:#f87171}
@keyframes toastIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}

/* ── ANIMATIONS TRANSITION ── */
.step.exit{
  animation:stepOut .2s ease forwards;
}
@keyframes stepOut{to{opacity:0;transform:translateY(-10px)}}

/* ── SAFE AREA ── */
@supports(padding-bottom:env(safe-area-inset-bottom)){
  .content{padding-bottom:calc(32px + env(safe-area-inset-bottom))}
}
</style>
<script src="/loyalcard-supabase.js"></script>
</head>
<body>

<div class="bg-glow"></div>

<div class="app" id="app">

  <!-- HEADER -->
  <div class="header">
    <div class="logo">Loyal<span>Card</span></div>
    <button class="back-btn" id="back-btn" onclick="goBack()" style="display:none">←</button>
  </div>

  <!-- PROGRESS -->
  <div class="progress-wrap" id="progress-wrap">
    <div class="prog-steps" id="prog-steps">
      <div class="prog-step"><div class="prog-fill" id="p1" style="width:0%"></div></div>
      <div class="prog-step"><div class="prog-fill" id="p2" style="width:0%"></div></div>
      <div class="prog-step"><div class="prog-fill" id="p3" style="width:0%"></div></div>
      <div class="prog-step"><div class="prog-fill" id="p4" style="width:0%"></div></div>
    </div>
    <div class="prog-label" id="prog-label">1 / 4</div>
  </div>

  <div class="content">

    <!-- ════ STEP 1 — NOM DE LA BOUTIQUE ════ -->
    <div class="step active" id="step-1">
      <div class="step-icon">🏪</div>
      <div class="step-title">Comment s'appelle<br><em>ta boutique ?</em></div>
      <div class="step-sub">Un seul champ. C'est tout ce dont on a besoin pour commencer.</div>

      <input class="shop-input" id="shop-name" type="text"
        placeholder="Ex: Café Touba, Épicerie Ndiaye..."
        autocomplete="off" autocorrect="off"
        maxlength="60"
        oninput="updateCTA1()"
        onkeydown="if(event.key==='Enter')nextStep(1)"/>

      <div class="type-grid" id="type-grid">
        <div class="type-card" data-type="restaurant" onclick="selectType(this)">
          <span class="type-emoji">🍽️</span>
          <div class="type-name">Restaurant / Café</div>
          <div class="type-hint">Thiébou dieune, café touba...</div>
        </div>
        <div class="type-card" data-type="epicerie" onclick="selectType(this)">
          <span class="type-emoji">🛒</span>
          <div class="type-name">Épicerie / Boutique</div>
          <div class="type-hint">Alimentation, produits...</div>
        </div>
        <div class="type-card" data-type="beaute" onclick="selectType(this)">
          <span class="type-emoji">💅</span>
          <div class="type-name">Beauté / Coiffure</div>
          <div class="type-hint">Salon, tresses, soins...</div>
        </div>
        <div class="type-card" data-type="service" onclick="selectType(this)">
          <span class="type-emoji">🔧</span>
          <div class="type-name">Service / Autre</div>
          <div class="type-hint">Livraison, pressing...</div>
        </div>
      </div>

      <button class="cta" id="cta-1" onclick="nextStep(1)" disabled>
        <span class="cta-label">Continuer →</span>
        <span class="spin"></span>
      </button>
    </div>

    <!-- ════ STEP 2 — RÉCOMPENSE ════ -->
    <div class="step" id="step-2">
      <div class="step-icon">🎁</div>
      <div class="step-title">Quelle est ta<br><em>récompense ?</em></div>
      <div class="step-sub">Après combien d'achats tu offres quelque chose à ton client ?</div>

      <div style="font-size:.72rem;color:var(--tx3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px">Nombre d'achats →</div>
      <div class="reward-num-row">
        <div class="rnum-btn" data-num="5" onclick="selectNum(this)">5</div>
        <div class="rnum-btn" data-num="8" onclick="selectNum(this)">8</div>
        <div class="rnum-btn selected" data-num="10" onclick="selectNum(this)">10</div>
        <div class="rnum-btn" data-num="15" onclick="selectNum(this)">15</div>
        <div class="rnum-btn" data-num="20" onclick="selectNum(this)">20</div>
      </div>

      <div style="font-size:.72rem;color:var(--tx3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px">Tu offres quoi ?</div>
      <div class="reward-examples" id="reward-examples"></div>
      <input class="reward-input" id="reward-desc" type="text"
        placeholder="Ex: Un café gratuit, 10% de réduction..."
        autocomplete="off" oninput="updateCTA2()"
        onkeydown="if(event.key==='Enter')nextStep(2)"/>

      <div class="hint">💡 Tu peux changer ça à tout moment dans tes paramètres</div>

      <button class="cta" id="cta-2" onclick="nextStep(2)" disabled>
        <span class="cta-label">C'est ma récompense →</span>
        <span class="spin"></span>
      </button>
      <div class="later-link" onclick="skipReward()">Décider plus tard</div>
    </div>

    <!-- ════ STEP 3 — TÉLÉPHONE ════ -->
    <div class="step" id="step-3">
      <div class="step-icon">📱</div>
      <div class="step-title">Ton numéro<br><em>de téléphone</em></div>
      <div class="step-sub">On t'envoie un code SMS pour sécuriser ton compte. Pas de mot de passe à retenir.</div>

      <div class="wave-pill">
        <div class="wave-dot"></div>
        <div class="wave-txt">Sénégal · +221 · Opérateurs Orange, Wave, Free</div>
      </div>

      <div class="phone-row">
        <div class="country-badge">
          <span class="country-flag">🇸🇳</span>
          <span>+221</span>
        </div>
        <input class="phone-input" id="phone-input" type="tel"
          placeholder="77 000 00 00"
          maxlength="12"
          inputmode="numeric"
          autocomplete="tel"
          oninput="formatPhone(this)"
          onkeydown="if(event.key==='Enter')nextStep(3)"/>
      </div>

      <div class="hint">
        <span>🔒</span>
        <span>Ton numéro ne sera jamais partagé ni vendu</span>
      </div>

      <button class="cta" id="cta-3" onclick="nextStep(3)" disabled>
        <span class="cta-label">Envoyer le code SMS →</span>
        <span class="spin"></span>
      </button>
    </div>

    <!-- ════ STEP 4 — OTP ════ -->
    <div class="step" id="step-4">
      <div class="step-icon">💬</div>
      <div class="step-title">Code reçu<br><em>par SMS</em></div>
      <div class="step-sub" id="otp-sub">Saisis les 4 chiffres envoyés au <strong id="phone-display"></strong></div>

      <div class="otp-row">
        <input class="otp-digit" id="otp0" type="tel" inputmode="numeric" maxlength="1" onkeyup="otpKey(this,0)" oninput="otpInput(this,0)"/>
        <input class="otp-digit" id="otp1" type="tel" inputmode="numeric" maxlength="1" onkeyup="otpKey(this,1)" oninput="otpInput(this,1)"/>
        <input class="otp-digit" id="otp2" type="tel" inputmode="numeric" maxlength="1" onkeyup="otpKey(this,2)" oninput="otpInput(this,2)"/>
        <input class="otp-digit" id="otp3" type="tel" inputmode="numeric" maxlength="1" onkeyup="otpKey(this,3)" oninput="otpInput(this,3)"/>
      </div>

      <button class="cta" id="cta-4" onclick="verifyOTP()" disabled>
        <span class="cta-label">Vérifier →</span>
        <span class="spin"></span>
      </button>

      <div class="resend-row">
        <button class="resend-btn" id="resend-btn" disabled>
          Renvoyer le code <span id="resend-count"></span>
        </button>
      </div>

      <div class="hint" style="justify-content:center;margin-top:10px">
        <span>💡</span>
        <span>Pour le test : utilise le code <strong style="color:var(--green2)">1234</strong></span>
      </div>
    </div>

    <!-- ════ SUCCESS ════ -->
    <div class="step" id="step-success">
      <div class="success-wrap">
        <div class="success-icon">🎉</div>
        <div class="success-title">Bienvenue<br><em id="success-name"></em></div>
        <div class="success-sub">Ton espace est prêt. Tu peux scanner ta première carte client maintenant.</div>

        <div class="confirm-card">
          <div class="confirm-row">
            <span class="confirm-key">Boutique</span>
            <span class="confirm-val" id="c-shop"></span>
          </div>
          <div class="confirm-row">
            <span class="confirm-key">Type</span>
            <span class="confirm-val" id="c-type"></span>
          </div>
          <div class="confirm-row">
            <span class="confirm-key">Récompense</span>
            <span class="confirm-val" id="c-reward"></span>
          </div>
          <div class="confirm-row">
            <span class="confirm-key">Téléphone</span>
            <span class="confirm-val" id="c-phone"></span>
          </div>
          <div class="confirm-row">
            <span class="confirm-key">Plan</span>
            <span class="confirm-val" style="color:var(--green2)">Gratuit — 30 jours</span>
          </div>
        </div>

        <button class="cta" onclick="launchApp()">
          <span>📷 Scanner mon premier client</span>
        </button>
        <button class="cta-ghost" onclick="goToDashboard()">
          Aller au tableau de bord
        </button>
      </div>
    </div>

  </div>
</div>

<!-- TOAST -->
<div class="toast-wrap" id="toasts"></div>

<script>
// ════════════════════════════════════════
// STATE
// ════════════════════════════════════════
const STATE = {
  step: 1,
  shopName: '',
  shopType: '',
  rewardNum: 10,
  rewardDesc: '',
  phone: '',
  otp: ['','','',''],
  resendTimer: null,
};

const TYPE_LABELS = {
  restaurant: '🍽️ Restaurant / Café',
  epicerie:   '🛒 Épicerie / Boutique',
  beaute:     '💅 Beauté / Coiffure',
  service:    '🔧 Service / Autre',
};

const REWARD_EXAMPLES = {
  restaurant: ['Un café gratuit','Un repas offert','10% de réduction','Une boisson offerte'],
  epicerie:   ['500 FCFA offerts','1 kg de sucre gratuit','10% sur les courses','Un produit offert'],
  beaute:     ['Un soin offert','15% de réduction','Manucure gratuite','Tresses 50% off'],
  service:    ['Une livraison gratuite','10% de réduction','Service prioritaire','Bon de 1000 FCFA'],
};

// ════════════════════════════════════════
// PROGRESS
// ════════════════════════════════════════
function updateProgress(step) {
  for (let i = 1; i <= 4; i++) {
    const fill = document.getElementById('p' + i);
    if (!fill) continue;
    if (i < step)      fill.style.width = '100%';
    else if (i === step) fill.style.width = '50%';
    else               fill.style.width = '0%';
  }
  const lbl = document.getElementById('prog-label');
  if (lbl) lbl.textContent = step + ' / 4';

  const back = document.getElementById('back-btn');
  if (back) back.style.display = step > 1 && step < 5 ? 'flex' : 'none';
}

// ════════════════════════════════════════
// STEP NAVIGATION
// ════════════════════════════════════════
function goTo(n) {
  const prev = document.getElementById('step-' + (STATE.step === 5 ? 'success' : STATE.step));
  if (prev) {
    prev.classList.remove('active');
    prev.classList.add('exit');
    setTimeout(() => prev.classList.remove('exit'), 200);
  }
  STATE.step = n;
  const next = document.getElementById(n === 5 ? 'step-success' : 'step-' + n);
  if (next) setTimeout(() => next.classList.add('active'), 50);
  updateProgress(Math.min(n, 4));
  window.scrollTo(0, 0);
}

function goBack() {
  if (STATE.step <= 1) return;
  const cur = document.getElementById('step-' + STATE.step);
  if (cur) cur.classList.remove('active');
  STATE.step--;
  const prev = document.getElementById('step-' + STATE.step);
  if (prev) prev.classList.add('active');
  updateProgress(STATE.step);
}

function nextStep(from) {
  if (from === 1) {
    STATE.shopName = document.getElementById('shop-name').value.trim();
    if (!STATE.shopName) return;
    // update reward examples
    const exWrap = document.getElementById('reward-examples');
    const examples = REWARD_EXAMPLES[STATE.shopType] || REWARD_EXAMPLES.restaurant;
    exWrap.innerHTML = examples.map(e =>
      `<div class="rex" onclick="useExample(this,'${e}')">${e}</div>`
    ).join('');
    goTo(2);
  } else if (from === 2) {
    STATE.rewardDesc = document.getElementById('reward-desc').value.trim() || 'Récompense à définir';
    goTo(3);
  } else if (from === 3) {
    sendOTP();
  }
}

function skipReward() {
  STATE.rewardDesc = 'À définir';
  goTo(3);
}

// ════════════════════════════════════════
// STEP 1 — SHOP TYPE
// ════════════════════════════════════════
function selectType(el) {
  document.querySelectorAll('.type-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  STATE.shopType = el.dataset.type;
  updateCTA1();
}

function updateCTA1() {
  const name = document.getElementById('shop-name').value.trim();
  const btn  = document.getElementById('cta-1');
  if (btn) btn.disabled = !name;
  if (name && !STATE.shopType) {
    // auto-select first if none selected
    const first = document.querySelector('.type-card');
    if (first && !document.querySelector('.type-card.selected')) {
      selectType(first);
    }
  }
}

// ════════════════════════════════════════
// STEP 2 — REWARD
// ════════════════════════════════════════
function selectNum(el) {
  document.querySelectorAll('.rnum-btn').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
  STATE.rewardNum = parseInt(el.dataset.num);
}

function useExample(el, text) {
  document.getElementById('reward-desc').value = text;
  STATE.rewardDesc = text;
  updateCTA2();
  document.querySelectorAll('.rex').forEach(r => r.style.borderColor = '');
  el.style.borderColor = 'var(--green2)';
}

function updateCTA2() {
  const val = document.getElementById('reward-desc').value.trim();
  const btn = document.getElementById('cta-2');
  if (btn) btn.disabled = !val;
}

// ════════════════════════════════════════
// STEP 3 — PHONE
// ════════════════════════════════════════
function formatPhone(input) {
  let val = input.value.replace(/\D/g, '').slice(0, 9);
  // format: 77 000 00 00
  let fmt = '';
  if (val.length > 0) fmt = val.slice(0, 2);
  if (val.length > 2) fmt += ' ' + val.slice(2, 5);
  if (val.length > 5) fmt += ' ' + val.slice(5, 7);
  if (val.length > 7) fmt += ' ' + val.slice(7, 9);
  input.value = fmt;
  STATE.phone = val;
  const btn = document.getElementById('cta-3');
  if (btn) btn.disabled = val.length < 9;
}

// ════════════════════════════════════════
// STEP 3 — SEND OTP
// ════════════════════════════════════════
function sendOTP() {
  const btn = document.getElementById('cta-3');
  setLoading(btn, true);

  sbSendOTP(STATE.phone)
    .then(() => {
      setLoading(btn, false);
      goTo(4);
      document.getElementById('phone-display').textContent = '+221 ' + document.getElementById('phone-input').value;
      startResendTimer();
      setTimeout(() => document.getElementById('otp0').focus(), 300);
      toast('Code envoyé au +221 ' + document.getElementById('phone-input').value, 'ok');
    })
    .catch(err => {
      setLoading(btn, false);
      toast(err.message || 'Erreur envoi SMS', 'err');
    });
}

// ════════════════════════════════════════
// STEP 4 — OTP
// ════════════════════════════════════════
function otpInput(el, idx) {
  const val = el.value.replace(/\D/g, '').slice(-1);
  el.value = val;
  STATE.otp[idx] = val;
  el.classList.toggle('filled', !!val);

  if (val && idx < 3) {
    document.getElementById('otp' + (idx + 1)).focus();
  }

  const full = STATE.otp.join('');
  const btn  = document.getElementById('cta-4');
  if (btn) btn.disabled = full.length < 4;

  // Auto-verify when 4 digits entered
  if (full.length === 4) setTimeout(() => verifyOTP(), 200);
}

function otpKey(el, idx) {
  if (event.key === 'Backspace' && !el.value && idx > 0) {
    const prev = document.getElementById('otp' + (idx - 1));
    prev.value = '';
    prev.classList.remove('filled');
    STATE.otp[idx - 1] = '';
    prev.focus();
  }
}

function verifyOTP() {
  const code = STATE.otp.join('');
  const btn  = document.getElementById('cta-4');
  setLoading(btn, true);

  sbVerifyOTP(STATE.phone, code)
    .then(() => saveAndLaunch())
    .catch(err => {
      setLoading(btn, false);
      toast(err.message || 'Code incorrect', 'err');
      STATE.otp = ['','','',''];
      for (let i = 0; i < 4; i++) {
        const el = document.getElementById('otp' + i);
        el.value = ''; el.classList.remove('filled');
      }
      document.getElementById('otp0').focus();
    });
}

// ════════════════════════════════════════
// RESEND TIMER
// ════════════════════════════════════════
function startResendTimer() {
  let secs = 60;
  const btn = document.getElementById('resend-btn');
  const cnt = document.getElementById('resend-count');
  if (!btn || !cnt) return;
  btn.disabled = true;
  cnt.textContent = '(' + secs + 's)';
  if (STATE.resendTimer) clearInterval(STATE.resendTimer);
  STATE.resendTimer = setInterval(() => {
    secs--;
    if (secs <= 0) {
      clearInterval(STATE.resendTimer);
      btn.disabled = false;
      cnt.textContent = '';
      btn.onclick = () => { sendOTPAgain(); };
    } else {
      cnt.textContent = '(' + secs + 's)';
    }
  }, 1000);
}

function sendOTPAgain() {
  toast('Nouveau code envoyé', 'ok');
  startResendTimer();
  STATE.otp = ['','','',''];
  for (let i = 0; i < 4; i++) {
    const el = document.getElementById('otp' + i);
    el.value = '';
    el.classList.remove('filled');
  }
  document.getElementById('otp0').focus();
}

// ════════════════════════════════════════
// SAVE & LAUNCH
// ════════════════════════════════════════
function saveAndLaunch() {
  sbCreateMerchant({
    name:       STATE.shopName,
    type:       STATE.shopType,
    emoji:      { restaurant:'☕', epicerie:'🛒', beaute:'💅', service:'🔧' }[STATE.shopType] || '🏪',
    threshold:  STATE.rewardNum,
    rewardDesc: STATE.rewardDesc || 'Récompense',
    phone:      '+221' + STATE.phone,
  })
  .then(merchant => {
    // Succès
    document.getElementById('success-name').textContent = STATE.shopName;
    document.getElementById('c-shop').textContent       = STATE.shopName;
    document.getElementById('c-type').textContent       = TYPE_LABELS[STATE.shopType] || STATE.shopType;
    document.getElementById('c-reward').textContent     = STATE.rewardNum + ' achats → ' + (STATE.rewardDesc || 'Récompense');
    document.getElementById('c-phone').textContent      = '+221 ' + document.getElementById('phone-input').value;
    const pw = document.getElementById('progress-wrap');
    if (pw) pw.style.display = 'none';
    goTo(5);
  })
  .catch(err => {
    // Si le commerçant existe déjà (reconnexion)
    toast('Bienvenue ! Chargement de votre espace...', 'ok');
    setTimeout(() => { window.location.href = '/merchant'; }, 800);
  });
}

function launchApp() {
  toast('Ouverture du scanner...', 'ok');
  setTimeout(() => {
    window.location.href = '/merchant/scan'; // → page scanner
  }, 800);
}

function goToDashboard() {
  window.location.href = '/merchant/dashboard'; // → dashboard
}

// ════════════════════════════════════════
// UTILS
// ════════════════════════════════════════
function setLoading(btn, on) {
  if (!btn) return;
  btn.classList.toggle('loading', on);
  btn.disabled = on;
}

function toast(msg, type = 'ok') {
  const wrap = document.getElementById('toasts');
  const el = document.createElement('div');
  el.className = 'toast ' + type;
  el.innerHTML = (type === 'ok' ? '✓ ' : '✗ ') + msg;
  wrap.appendChild(el);
  setTimeout(() => el.remove(), 3000);
}

// ════════════════════════════════════════
// INIT
// ════════════════════════════════════════
updateProgress(1);

// Auto-focus shop name on load
window.addEventListener('load', () => {
  setTimeout(() => document.getElementById('shop-name')?.focus(), 400);
});
</script>
</body>
</html>
